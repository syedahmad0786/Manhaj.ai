# =============================================================================
# Server-only secrets (never prefix with NEXT_PUBLIC_)
# =============================================================================

# Resend — transactional email (operator-inbox notifications for new leads)
RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM must use a sender/domain verified in your Resend account.
RESEND_FROM=Manhaj <notifications@your-verified-domain.example>
RESEND_TO=ahmadbukhari4245@gmail.com

# Supabase — durable lead record (admin / service role key)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxx

# n8n — downstream automations (qualify → route → enrich)
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/manhaj-lead

# =============================================================================
# Public — exposed to the browser via NEXT_PUBLIC_ prefix
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://manhaj.ahmadbukhari.com

# Google Tag Manager container ID (also injected into the kiosk static HTML
# at build time via scripts/inject-kiosk-env.mjs).
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# CookieYes consent-script ID (drop the script-tag id from the <script src=...>)
NEXT_PUBLIC_COOKIEYES_ID=

# Cal.com link slug (not the full URL)
NEXT_PUBLIC_CAL_LINK=ahmad-bukhari/ai-consultancy-call-with-ab
