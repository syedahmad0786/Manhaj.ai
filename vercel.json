{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": "",
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/foundation", "destination": "/" },
    { "source": "/process", "destination": "/" },
    { "source": "/pricing", "destination": "/" },
    { "source": "/about", "destination": "/" },
    { "source": "/audit", "destination": "/" },
    { "source": "/kiosks", "destination": "/" },
    { "source": "/kiosks/command-center", "destination": "/" },
    { "source": "/kiosks/onboarding", "destination": "/" },
    { "source": "/kiosks/errorlens", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
